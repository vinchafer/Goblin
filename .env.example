# Goblin Environment Variables
# Copy this file to .env and fill in your values

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Web Application
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API Server
API_PORT=3001
NODE_ENV=development

# Stripe (later)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# AI Providers (later)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# TOGETHER_API_KEY=
# FIREWORKS_API_KEY=

# Encryption (for BYOK keys)
ENCRYPTION_KEY=generate-a-32-char-random-string-here

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3000/dashboard/settings/integrations/github-callback

# Stripe Billing
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_SEED=price_xxx
STRIPE_PRICE_CRAFT=price_xxx
STRIPE_PRICE_FORGE=price_xxx
