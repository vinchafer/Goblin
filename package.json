{
  "name": "goblin-monorepo",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "pnpm --filter \"./apps/**\" dev",
    "build": "pnpm --filter \"./packages/**\" build && pnpm --filter \"./apps/**\" build",
    "lint": "pnpm --recursive lint",
    "typecheck": "pnpm --recursive typecheck"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.5"
  },
  "packageManager": "pnpm@9.15.4"
}