# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Service Role key (SECRET — never expose to browser)
# Same page as above → "service_role" key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Encryption ──────────────────────────────────────────────────────────────
# 32-byte hex key for AES-256-GCM encryption of BYOK keys
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
# Create OAuth App: https://github.com/settings/developers
# Callback URL: https://api.justgoblin.com/api/github/callback
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:3001/api/github/callback

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Stripe Price IDs — geo-tiered (Build / Pro / Power × Tier 1/2/3).
# TIER1 = High income, TIER2 = Upper-middle, TIER3 = Lower-middle + Low.
# Display amounts live in apps/api/src/config/geo-pricing.ts (PLAN_PRICES);
# these env vars must point at the matching Stripe prices.
# TIER1 ids are required (checkout fallback); TIER2/3 optional.
STRIPE_PRICE_BUILD_TIER1=price_build_t1_id
STRIPE_PRICE_BUILD_TIER2=price_build_t2_id
STRIPE_PRICE_BUILD_TIER3=price_build_t3_id
STRIPE_PRICE_PRO_TIER1=price_pro_t1_id
STRIPE_PRICE_PRO_TIER2=price_pro_t2_id
STRIPE_PRICE_PRO_TIER3=price_pro_t3_id
STRIPE_PRICE_POWER_TIER1=price_power_t1_id
STRIPE_PRICE_POWER_TIER2=price_power_t2_id
STRIPE_PRICE_POWER_TIER3=price_power_t3_id

# ─── Web Push / VAPID ────────────────────────────────────────────────────────
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_CONTACT=mailto:hi@justgoblin.com

# ─── Storage (Backblaze B2, EU eu-central-003 / S3-compatible) ───────────────
# Create bucket: https://www.backblaze.com/b2/cloud-storage.html
STORAGE_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
STORAGE_KEY=your-access-key-id
STORAGE_SECRET=your-application-key
STORAGE_BUCKET=goblin-projects
STORAGE_REGION=auto

# ─── App URLs ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
PORT=3001

# ─── Optional: Free-API Pool (Layer 2 model routing) ────────────────────────
# Leave empty to disable the free tier routing
# GOOGLE_FREE_API_KEY=AIza...          # https://aistudio.google.com/app/apikey
# GROQ_FREE_API_KEY=gsk_...            # https://console.groq.com/keys
# CEREBRAS_FREE_API_KEY=csk-...        # https://cloud.cerebras.ai
# OPENROUTER_FREE_API_KEY=sk-or-...    # https://openrouter.ai/keys

# ─── Optional: LiteLLM Proxy ────────────────────────────────────────────────
# When set, Goblin routes all chat completions through LiteLLM first.
# Falls back to direct provider APIs if LiteLLM is not reachable.
# LITELLM_BASE_URL=http://localhost:4000     # e.g. http://litellm.your-domain.com
# LITELLM_API_KEY=sk-your-litellm-master-key

# ─── Support Email (Resend) ──────────────────────────────────────────────────
# Resend API key: https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key

# Where escalation emails go (support inbox)
SUPPORT_EMAIL_TO=support@justgoblin.com

# Sender address (must be on a verified Resend domain — the root justgoblin.com)
SUPPORT_EMAIL_FROM=Goblin Support <support@justgoblin.com>

# ─── Optional: Admin + Internal ─────────────────────────────────────────────
# Enables /api/admin routes
ADMIN_API_KEY=your-secret-admin-key

# Used for internal server-to-server calls (build status updates, etc.)
CRON_SECRET=your-secret-cron-key

# ─── Optional: Error Monitoring (Sentry) ────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_ENVIRONMENT=production
# LOG_LEVEL=info    # debug | info | warn | error

# ─── Optional: Better-Stack Heartbeat ───────────────────────────────────────
# Heartbeat URL pinged after each successful eval suite run.
# BETTERSTACK_HEARTBEAT_URL=https://uptime.betterstack.com/api/v1/heartbeat/XYZ

# ─── Optional: Admin gate ───────────────────────────────────────────────────
# Comma-separated Supabase user IDs allowed to access /admin/api/* endpoints.
# ADMIN_USER_IDS=uuid-1,uuid-2

# ─── Optional: Goblin-bundled models (Layer 2, API-first) ───────────────────
# Server-side-keyed inference (inverse of BYOK). Default OFF — while unset, the
# router never selects Layer 2 (code path unreachable). Sourced from a US wholesale
# per-token inference API; never name the provider on a public/marketing surface.
# See infra/GOBLIN_HOSTED_ACTIVATION.md.
#
# SECRET: the wholesale key lives ONLY in the Railway env var DEEPINFRA_API_KEY.
# Locally keep a PLACEHOLDER (empty or "set-in-railway") — never the real key.
# GOBLIN_HOSTED_API=true
# DEEPINFRA_API_KEY=set-in-railway
# GOBLIN_HOSTED_BASE_URL=https://api.deepinfra.com/v1/openai   # optional; this is the default
# GOBLIN_HOSTED_MODEL_EFFICIENT=deepseek-ai/DeepSeek-V3.2      # Goblin Swift (default tier)
# GOBLIN_HOSTED_MODEL_PREMIUM=moonshotai/Kimi-K2.6            # Goblin Forge (premium tier)
# GOBLIN_TRANSCRIBE_MODEL=openai/whisper-large-v3-turbo       # dictation fallback (C1); DeepInfra Whisper via the same key
#
# Investor-gated model-mapping endpoint (GET /api/investor/models). Shared secret
# that lets the PITCH deployment fetch the real Swift/Forge → underlying-model
# mapping server-to-server (sent in the `x-investor-token` header). Dedicated,
# narrowly-scoped token — NOT the admin key. Railway-only; placeholder locally.
# Unset → the endpoint denies every request (fail closed).
# INVESTOR_MODELS_TOKEN=set-in-railway

# ─── Optional: Eval Runner ──────────────────────────────────────────────────
# Goblin's own provider keys (NOT user BYOK) for daily eval suite.
# EVAL_ANTHROPIC_KEY=sk-ant-...
# EVAL_OPENAI_KEY=sk-proj-...
# EVAL_GEMINI_KEY=AIza...
# EVAL_GROQ_KEY=gsk_...
# Random 32-char hex secret for authenticating cron/manual eval triggers.
# Generate: openssl rand -hex 32
# EVAL_CRON_SECRET=

# ─── Optional: WAVE-H concurrency admission (H4) ────────────────────────────
# The single-box process caps how many agent runs may execute AT ONCE, so a flood
# can't exhaust the box or trip the shared circuit breaker (Code-DD N-1/N-6). These
# are founder knobs — generous defaults, no real user is throttled at current scale.
# Global ceiling on simultaneous agent runs in this process. 0 = disable the cap.
# AGENT_GLOBAL_MAX_CONCURRENT=50
# Per-user simultaneous agent runs. Generous for humans, a ceiling against fan-out.
# 0 = disable. Complements (does not replace) AGENT_RUNS_PER_HOUR.
# AGENT_MAX_CONCURRENT_PER_USER=2
# Retry-After (seconds) sent to a shed run; the client shows honest copy + auto-retries.
# AGENT_CAPACITY_RETRY_AFTER_SEC=8
