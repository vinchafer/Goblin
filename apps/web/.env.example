# ─── Supabase ────────────────────────────────────────────────────────────────
# Project URL from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Public anon key (safe to expose in browser) — same page as above
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── API ─────────────────────────────────────────────────────────────────────
# URL of the Goblin API server (apps/api)
# Local (DEV-SAFE): http://localhost:3001 — routes through the LOCAL guarded API so the
#   B3 dev-safety shield intercepts writes (see docs/DEV_SAFETY.md). REQUIRED to arm the
#   shield for `pnpm dev`.
# Production: https://api.justgoblin.com (or the Railway URL)
# NOTE: if unset, the web app auto-defaults to http://localhost:3001 in dev and the Railway
#   URL in prod. Pointing this at the Railway URL while developing BYPASSES the shield
#   (writes hit prod directly).
NEXT_PUBLIC_API_URL=http://localhost:3001

# Full URL of this web app (used for redirects, OG tags)
# Local: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── PWA / Push Notifications ────────────────────────────────────────────────
# Generate VAPID keys: npx web-push generate-vapid-keys
# Only the public key goes here (apps/api needs the private key)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# ─── Optional: Sentry ────────────────────────────────────────────────────────
# Browser-side DSN (safe to expose; rate-limited at Sentry).
# NEXT_PUBLIC_SENTRY_DSN=https://...@o0.ingest.sentry.io/0
# Auth token (build-time only — for source-map upload). Required for prod releases.
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=goblin
# SENTRY_PROJECT=goblin-web
