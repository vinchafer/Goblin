{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git push origin master 2>&1 || true",
            "timeout": 60,
            "statusMessage": "Pushing commits to GitHub..."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git push *)"
    ]
  }
}
